# =============================================================================
# Environment Variables for Pete/Campus Project
# =============================================================================
# Copy this file to .env and fill in your real values.
#   cp .env.example .env
# NEVER commit .env to git.
# =============================================================================

# ─── Backend Go ─────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgres://user:password@host:port/database?sslmode=disable
DATABASE_URL=postgres://USERNAME:PASSWORD@HOST:5432/DB_NAME?sslmode=disable

# JWT signing secret (min 32 bytes, use a strong random string)
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET_AT_LEAST_32_CHARS

# ─── Pete Backend (pete_service.pyw) ────────────────────────────────────────
# DeepSeek API key for AI backend
DEEPSEEK_API_KEY=sk-YOUR_DEEPSEEK_API_KEY_HERE

# ─── WeChat Bridge ──────────────────────────────────────────────────────────
# WeChat PC auto-reply pipe port
WECHAT_PIPE_PORT=8766

# ─── Claude Code ────────────────────────────────────────────────────────────
# Anthropic API key
ANTHROPIC_API_KEY=sk-ant-YOUR_ANTHROPIC_API_KEY_HERE

# ─── Server Deployment ──────────────────────────────────────────────────────
# Bind host and port for Go API server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
