# ZAP context configuration for 校园即时通 campus API
# Sourced by zap_scan.sh — shell format, not ZAP native format.
# For native ZAP context format, import via ZAP UI > Session > Import Context.

# Target URL
ZAP_TARGET_URL="http://139.196.50.134"

# Context name (appears in ZAP session tree)
ZAP_CONTEXT_NAME="campus-api"

# Include regex — paths to scan (comma-separated for multiple)
# Passed as -I /api/ to zap-baseline.py (one flag per include)
ZAP_INCLUDE_PATHS=("/api/")

# Exclude regex — paths to skip (noise reduction)
# Passed as -X /api/health -X /api/version to zap-baseline.py
ZAP_EXCLUDE_PATHS=(
  "/api/health"
  "/api/version"
)

# Authentication
# zap-baseline.py uses stateless scanning (no auth context by default).
# For authenticated scanning, use zap-full-scan.py with -a flag and
# a ZAP context file (.context) containing auth credentials.
ZAP_AUTH_TYPE="Bearer Token"
ZAP_AUTH_HEADER="Authorization: Bearer <token>"

# Technology stack (for ZAP technology fingerprinting)
ZAP_TECHNOLOGIES="Python,FastAPI,PostgreSQL"

# Alert threshold: PASS, WARN, FAIL
# Pass -l PASS to report all, -l WARN for medium+, -l FAIL for high+
ZAP_ALERT_THRESHOLD="FAIL"
