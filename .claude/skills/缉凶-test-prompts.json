[
  {
    "id": 1,
    "scenario": "T0 确定性 bug — 完整 7-Phase 结构",
    "prompt": "用户报名活动时报 500 错误 — 帮我找出根因并修好",
    "assert": {
      "mustContain": ["T0", "Phase 1", "Phase 2", "Phase 3", "Phase 4", "Phase 5", "Phase 6", "Phase 7", "Divergence Point", "Causal Chain", "Counterfactual", "confidence", "Root Cause"],
      "mustNotContain": [],
      "regex": ["Phase [1-7].*Classify|Phase [1-7].*Search|Phase [1-7].*Trace|Phase [1-7].*Analyze|Phase [1-7].*Fix|Phase [1-7].*Verify|Phase [1-7].*(Report|Grow)", "T[0-7]", "TIER[12]", "file:.*line", "3a|3b|3c"],
      "lengthMin": 3000,
      "lengthMax": 12000
    },
    "expect": "所有 7 Phase 存在。T0-T7 分类学完整。TIER1/TIER2 双路径。Phase 3a/3b/3c 子步骤。Phase 4a-4e 完整分析链。"
  },
  {
    "id": 2,
    "scenario": "T4 回归 bug — git bisect",
    "prompt": "login 功能昨天还好好的，今天就报 500 了 — 帮我查",
    "assert": {
      "mustContain": ["T4", "bisect", "git log", "commit", "Phase 1"],
      "mustNotContain": [],
      "regex": ["bisect (start|bad|good|reset)", "T4"],
      "lengthMin": 3000,
      "lengthMax": 12000
    },
    "expect": "Phase 1→T4。2b git bisect 定位引入 commit。不猜配置/缓存。"
  },
  {
    "id": 3,
    "scenario": "T1 海森堡 — 观测者效应",
    "prompt": "这个 race condition 在 debug 模式下消失了，生产环境偶发出现",
    "assert": {
      "mustContain": ["T1", "Heisenbug", "观测者", "strace", "时序"],
      "mustNotContain": [],
      "regex": ["T1|Heisenbug", "(观测者|observer)", "(strace|eBPF|ltrace)"],
      "lengthMin": 3000,
      "lengthMax": 12000
    },
    "expect": "Phase 1→T1。观测者效应警告。低开销观测(strace/eBPF)。时序敏感诊断。"
  },
  {
    "id": 4,
    "scenario": "T2 多因 — Counterfactual",
    "prompt": "用户有时看不到活动列表 — 换了 3 种修法都只能部分解决",
    "assert": {
      "mustContain": ["T2", "Counterfactual", "独立"],
      "mustNotContain": [],
      "regex": ["T2|Multi-Cause", "每.*因素|factor.*factor"],
      "lengthMin": 3000,
      "lengthMax": 12000
    },
    "expect": "Phase 1→T2。每因素独立 Counterfactual。修一个≠根因。"
  },
  {
    "id": 5,
    "scenario": "T3 静默 — 不变量 + diff",
    "prompt": "用户积分有时莫名其妙变少了，没有报错没有 crash",
    "assert": {
      "mustContain": ["T3", "Silent", "diff", "中间断言"],
      "mustNotContain": [],
      "regex": ["T3|Silent", "diff.*before|before.*diff", "(assert|Assertion)"],
      "lengthMin": 3000,
      "lengthMax": 12000
    },
    "expect": "Phase 1→T3(Silent)。不变量推断+数据 diff。中间断言定位。"
  },
  {
