# Rate limiting zones (must be in http block — move to /etc/nginx/nginx.conf if needed)
limit_req_zone $binary_remote_addr zone=login:10m rate=5r/m;
limit_req_zone $binary_remote_addr zone=register:10m rate=3r/h;
limit_req_zone $binary_remote_addr zone=api:10m rate=60r/m;
limit_conn_zone $binary_remote_addr zone=addr:10m;

server {
    listen 80;
    server_name _;
    client_max_body_size 10M;
    server_tokens off;
    limit_conn addr 500;

    # Security headers
    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-eval' 'wasm-unsafe-eval' https://www.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https://fonts.gstatic.com; connect-src 'self' http://139.196.50.134 https://www.gstatic.com https://fonts.gstatic.com; frame-ancestors 'self';" always;

    # Flutter Web
    location /web/ {
        alias /app/static/web/;
        index index.html;
        try_files $uri $uri/ /web/index.html;
    }

    # Block probes
    location ~* \.(php|asp|aspx|jsp|cgi)$ { return 444; }
    location ~* (/wp-admin|/wp-login|/xmlrpc\.php) { return 444; }

    # Block direct upload access
    location /static/uploads/ { deny all; }

    # APK download
    location = /static/app-release.apk {
        add_header Cache-Control "no-cache, no-store, must-revalidate";
        alias /app/static/app-release.apk;
    }

    # API proxy
    location / {
        limit_req zone=api burst=50 nodelay;
        proxy_pass http://127.0.0.1:9500;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
    }

    location /api/login {
        limit_req zone=login burst=20 nodelay;
        proxy_pass http://127.0.0.1:9500;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /api/register {
        limit_req zone=register burst=3 nodelay;
        proxy_pass http://127.0.0.1:9500;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Netdata monitoring (password-protected)
    location /netdata/ {
        proxy_pass http://127.0.0.1:19999/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        auth_basic "Netdata Monitoring";
        auth_basic_user_file /etc/nginx/.netdata-htpasswd;
    }
}
